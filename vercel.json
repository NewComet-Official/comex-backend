{
  "version": 2,
  "routes": [
    { "source": "/widget.js",
    "dest": "/public/widget.js"
    },
    {
      "source": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "source": "/(dashboard|new-deployment|third-party-integrations|analytics|reports|human-dashboard|employee-dashboard|settings)",
      "dest": "/index.html"
    }
  ]
}
